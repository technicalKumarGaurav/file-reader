{
    "name": "technicalkumargaurav/file-reader",
    "description": "A PHP application to read and process Excel, CSV, PDF files.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "pdf",
        "excel",
        "csv",
        "reader",
        "parser",
        "php"
    ],
    "homepage": "https://github.com/technicalKumarGaurav/file-reader",
    "autoload": {
        "psr-4": {
            "Kumar\\FileReader\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Kumar Gaurav"
        }
    ],
    "require": {
        
        "phpoffice/phpspreadsheet": "^4.0 || ^5.0",
        "smalot/pdfparser": "^2.12"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
